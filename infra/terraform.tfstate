            "validate_schema": true,
            "wait": null,
            "wait_for_rollout": true,
            "yaml_body": "apiVersion: autoscaling/v2\r\nkind: HorizontalPodAutoscaler # Cria um HPA, responsável por aumentar ou diminuir Pods automaticamente com base em métricas\r\nmetadata:\r\n  name: api-hpa # HPA chamado api-hpa dentro do namespace oficina\r\n  namespace: oficina\r\nspec:\r\n  scaleTargetRef:\r\n    apiVersion: apps/v1\r\n    kind: Deployment # Esse HPA \"controla\" o deployment api\r\n    name: api\r\n  minReplicas: 1 # Limites de escala\r\n  maxReplicas: 5\r\n  metrics:\r\n    - type: Resource\r\n      resource:\r\n        name: cpu # HPA vai usar CPU como critério de escala\r\n        target:\r\n          type: Utilization\r\n          averageUtilization: 50 ",
            "yaml_body_parsed": "apiVersion: autoscaling/v2\nkind: HorizontalPodAutoscaler\nmetadata:\n  name: api-hpa\n  namespace: oficina\nspec:\n  maxReplicas: 5\n  metrics:\n  - resource:\n      name: cpu\n      target:\n        averageUtilization: 50\n        type: Utilization\n    type: Resource\n  minReplicas: 1\n  scaleTargetRef:\n    apiVersion: apps/v1\n    kind: Deployment\n    name: api\n",
            "yaml_incluster": "1581b193496afb69cf8e814adbaf5b067f008f18904f9eca0489dc94253b274f"
