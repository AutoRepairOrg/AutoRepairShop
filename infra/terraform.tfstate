            "ignore_fields": null,
            "kind": "Deployment",
            "live_manifest_incluster": "9d998b80e9bd3746a7bf0a2a6a7f75f57b9562959f14668a94c2cc269d028596",
            "live_uid": "60c2f9f5-1c08-458b-b447-d7346b226e63",
            "name": "api",
            "namespace": "oficina",
            "override_namespace": null,
            "sensitive_fields": null,
            "server_side_apply": false,
            "timeouts": null,
            "uid": "60c2f9f5-1c08-458b-b447-d7346b226e63",
            "validate_schema": true,
            "wait": null,
            "wait_for_rollout": true,
            "yaml_body": "apiVersion: apps/v1\r\nkind: Deployment\r\nmetadata:\r\n  name: api\r\n  namespace: oficina # Cria um Deployment chamado api dentro do namespace oficina.\r\nspec:\r\n  replicas: 1 # Garante que sempre exista 1 Pod rodando dessa aplicação.\r\n  selector:\r\n    matchLabels:\r\n      app: api # Deployment gerencia todos os Pods que tiverem o label app=api\r\n  template:\r\n    metadata:\r\n      labels:\r\n        app: api # Cada Pod criado terá o label app=api\r\n    spec:\r\n      imagePullSecrets:\r\n        - name: ghcr-secret # Kubernetes deve usar o Secret ghcr-secret para autenticar no GitHub Container Registry (GHCR) ao baixar a imagem privada\r\n      containers:\r\n        - name: api # Define um container chamado api dentro do Pod\r\n          image: ghcr.io/dhiuliaantunes/autorepairshop-api:latest # Baixa a imagem mais atualizada\r\n          resources:\r\n            requests:\r\n              cpu: \"100m\"     \r\n              memory: \"128Mi\"  # O Kubernetes reserva no mínimo: 0.1 CPU e 128 MB RAM\r\n            limits:\r\n              cpu: \"500m\"\r\n              memory: \"256Mi\" # Container não deve ultrapassar 0.5 CPU 256 MB RAM\r\n          imagePullPolicy: Always # Sempre tenta baixar novamente, mesmo que já exista\r\n          ports:\r\n            - containerPort: 8080 # Porta a ser utilizada por services e probes\r\n          envFrom: # Injeção de todas as chaves desses recursos como variáveis de ambiente no container\r\n            - configMapRef:\r\n                name: api-config\r\n            - secretRef:\r\n                name: sqlserver-secret\r\n            - secretRef:\r\n                name: api-secrets",
            "yaml_body_parsed": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: api\n  namespace: oficina\nspec:\n  replicas: 1\n  selector:\n    matchLabels:\n      app: api\n  template:\n    metadata:\n      labels:\n        app: api\n    spec:\n      containers:\n      - envFrom:\n        - configMapRef:\n            name: api-config\n        - secretRef:\n            name: sqlserver-secret\n        - secretRef:\n            name: api-secrets\n        image: ghcr.io/dhiuliaantunes/autorepairshop-api:latest\n        imagePullPolicy: Always\n        name: api\n        ports:\n        - containerPort: 8080\n        resources:\n          limits:\n            cpu: 500m\n            memory: 256Mi\n          requests:\n            cpu: 100m\n            memory: 128Mi\n      imagePullSecrets:\n      - name: ghcr-secret\n",
            "yaml_incluster": "9d998b80e9bd3746a7bf0a2a6a7f75f57b9562959f14668a94c2cc269d028596"
          },
