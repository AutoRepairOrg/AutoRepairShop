            "wait_for_rollout": true,
            "yaml_body": "apiVersion: v1\r\nkind: ConfigMap # Usado para armazenar configurações não sensíveis da aplicação\r\nmetadata:\r\n  name: api-config\r\n  namespace: oficina # ConfigMap chamado api-config no namespace oficina.\r\ndata:\r\n  ASPNETCORE_ENVIRONMENT: \"Production\" # Diz a aplicação .NET que ela está rodando em ambiente de produção\r\n  \r\n  DB_HOST: \"sqlserver\" # Configurações de banco de dados\r\n  DB_PORT: \"1433\"\r\n  DB_NAME: \"AutoRepairShopDb\"\r\n\r\n  LOG_LEVEL: \"Information\" # Nível mínimo de log",
            "yaml_body_parsed": "apiVersion: v1\ndata:\n  ASPNETCORE_ENVIRONMENT: Production\n  DB_HOST: sqlserver\n  DB_NAME: AutoRepairShopDb\n  DB_PORT: \"1433\"\n  LOG_LEVEL: Information\nkind: ConfigMap\nmetadata:\n  name: api-config\n  namespace: oficina\n",
