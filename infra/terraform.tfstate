            "yaml_body": "apiVersion: v1\r\nkind: Secret # Armazenamento de configurações/infos sensíveis\r\nmetadata:\r\n  name: api-secrets # Nome da Secret\r\n  namespace: oficina # Namespace em que está sendo criada\r\ntype: Opaque # Tipo genérico de sectet utilizado como chave/valor\r\nstringData:\r\n  Jwt__Key: \"MinhaChaveSuperSecretaComMaisDe256Bits12345678901234567890\"\r\n  Jwt__Issuer: \"AutoRepairShop\"\r\n  Jwt__Audience: \"AutoRepairShopUsers\"\r\n  Jwt__ExpiresInMinutes: \"60\"",
            "yaml_body_parsed": "apiVersion: v1\nkind: Secret\nmetadata:\n  name: api-secrets\n  namespace: oficina\nstringData:\n  Jwt__Audience: AutoRepairShopUsers\n  Jwt__ExpiresInMinutes: \"60\"\n  Jwt__Issuer: AutoRepairShop\n  Jwt__Key: MinhaChaveSuperSecretaComMaisDe256Bits12345678901234567890\ntype: Opaque\n",
