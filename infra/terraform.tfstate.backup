            "yaml_body": "apiVersion: apps/v1\r\nkind: Deployment\r\nmetadata:\r\n  name: api\r\n  namespace: oficina\r\nspec:\r\n  replicas: 1\r\n  selector:\r\n    matchLabels:\r\n      app: api\r\n  template:\r\n    metadata:\r\n      labels:\r\n        app: api\r\n    spec:\r\n      imagePullSecrets:\r\n        - name: ghcr-secret   \r\n      containers:\r\n        - name: api\r\n          image: ghcr.io/dhiuliaantunes/autorepairshop-api:latest\r\n          resources:\r\n            requests:\r\n              cpu: \"100m\"\r\n              memory: \"128Mi\"\r\n            limits:\r\n              cpu: \"500m\"\r\n              memory: \"256Mi\"\r\n          imagePullPolicy: Always\r\n          ports:\r\n            - containerPort: 8080\r\n          envFrom:\r\n            - configMapRef:\r\n                name: api-config\r\n            - secretRef:\r\n                name: sqlserver-secret\r\n            - secretRef:\r\n                name: api-secrets",
            "yaml_body_parsed": "apiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: api\n  namespace: oficina\nspec:\n  replicas: 1\n  selector:\n    matchLabels:\n      app: api\n  template:\n    metadata:\n      labels:\n        app: api\n    spec:\n      containers:\n      - envFrom:\n        - configMapRef:\n            name: api-config\n        - secretRef:\n            name: sqlserver-secret\n        - secretRef:\n            name: api-secrets\n        image: ghcr.io/dhiuliaantunes/autorepairshop-api:latest\n        imagePullPolicy: Always\n        name: api\n        ports:\n        - containerPort: 8080\n        resources:\n          limits:\n            cpu: 500m\n            memory: 256Mi\n          requests:\n            cpu: 100m\n            memory: 128Mi\n      imagePullSecrets:\n      - name: ghcr-secret\n",
